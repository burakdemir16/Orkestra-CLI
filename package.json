{
  "name": "orkestra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Yerel CLI ajanlarini tek panelden yoneten AI orkestra studyosu.",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch apps/server/src/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "start": "tsx apps/server/src/index.ts",
    "test": "tsx --test apps/server/src/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^11.8.1",
    "concurrently": "^10.0.3",
    "fastify": "^5.2.1",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2"
  }
}
